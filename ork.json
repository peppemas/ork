{
  "vm": {
    "memory": "2G",
    "kernel": "orkvm-kernel",
    "initrd": "orkvm-initrd.img",
    "cmdline": "orkvm-cmdline",
    "qemu_path": "C:\\Program Files\\qemu\\qemu-system-x86_64.exe",
    "accelerator": "auto"
  },
  "image": {
    "linuxkit_path": "",
    "template": "templates/test-disk.yaml",
    "name": "orkvm",
    "format": "kernel+initrd"
  },
  "workspace": {
    "path": "workspace.img",
    "default_size": "100M",
    "mount": "/workspace"
  },
  "exec": {
    "host": "127.0.0.1",
    "ssh_port": 2222,
    "user": "root",
    "key_path": ".ork/id_rsa",
    "state_path": ".ork/vm.json",
    "ready_timeout": "60s"
  }
}
